# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=NextHub

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX

# Resend (newsletter emails)
RESEND_API_KEY=re_XXXXXXXXXX
RESEND_FROM_EMAIL=hello@yourdomain.com

# OAuth (configured in Supabase dashboard)
# GITHUB_CLIENT_ID and GITHUB_CLIENT_SECRET go in Supabase Auth settings
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET go in Supabase Auth settings
